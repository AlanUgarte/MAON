# ── Base de datos ───────────────────────────────────────────
DATABASE_URL="postgresql://crm:crm_password@localhost:5432/crm_comercial?schema=public"

# ── App ─────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET="cambiar-esto-por-un-secreto-largo-y-aleatorio"
JWT_EXPIRES_IN=7d

# ── IA · Claude (Anthropic) ─────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
AI_MODEL="claude-haiku-4-5-20251001"
AI_ENABLED=false   # modo GRATIS sin costo. true + ANTHROPIC_API_KEY para Claude real
# Respuestas automáticas al cliente (FAQ). Por defecto NO responde solo.
AUTO_REPLY_ENABLED=false
# Análisis de conversaciones y leads con Claude (score, intención, insights)
AI_ANALYSIS_ENABLED=true
# Blindaje de costos: el CRM NO envía nada fuera de la ventana gratis de WhatsApp
FREE_WINDOW_ONLY=true
# Control de inventario. false = no maneja stock (igual cuenta unidades vendidas)
STOCK_CONTROL_ENABLED=false

# ── WhatsApp Business Cloud API ─────────────────────────────
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN="mi-token-de-verificacion"
WHATSAPP_API_VERSION=v21.0

# ── Meta Ads (opcional) ─────────────────────────────────────
META_ACCESS_TOKEN=""
META_AD_ACCOUNT_ID=""
